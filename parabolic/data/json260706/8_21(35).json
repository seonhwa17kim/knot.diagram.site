				"(-1 + y)*(-1 + 4*y - 2*y^2 + y^3 - y^4)*(1 - y + 4*y^2 - y^3 + y^4)",
				"(-1 + y)*(1 - 12*y - 2*y^2 + 3*y^3 + y^4)*(1 + 7*y + 16*y^2 + 7*y^3 + y^4)"
			]
		}
	]
}